{
  "permissions": {
    "allow": [
      "WebFetch",
      "WebSearch",
      "Fetch(*)",
      "Bash(*)",
      "mcp__Grok__search_x",
      "mcp__Grok__ask",
      "mcp__playwright__*"
    ],
    "deny": [
      "Bash(rm:*)",
      "Bash(rmdir:*)",
      "Bash(:* rm *)",
      "Bash(:* rm -*)",
      "Bash(find:* -delete*)",
      "Bash(find:* -exec rm*)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -f*)",
      "Bash(git branch -D*)"
    ]
  }
}
